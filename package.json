{
  "name": "@tubox/veyra-sdk",
  "version": "1.0.1",
  "description": "The official Veyra Node.js / TypeScript SDK",
  "author": "Veyra",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./streaming": {
      "import": {
        "types": "./dist/lib/streamHelpers.d.ts",
        "default": "./dist/lib/streamHelpers.mjs"
      },
      "require": {
        "types": "./dist/lib/streamHelpers.d.cts",
        "default": "./dist/lib/streamHelpers.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write src tests docs examples",
    "docs": "typedoc --options typedoc.json && node --import tsx scripts/syncApiReferenceDocs.ts",
    "prepublishOnly": "node --import tsx ./scripts/checkVersion.ts",
    "smoke:live": "node --import tsx scripts/liveSmokeTest.ts",
    "ci:all": "npm run typecheck && npm run lint && npm test && npm run build && npm run docs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.6.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
